$name?="nucleo-h755zi-q-smoke-tap"
$bin?=@/Users/giuliomastromartino/Documents/Polispace/DEV/MICRO_ROS_ETH-main/Test_Board_Sensore/Makefile/CM4_smoke/build/Polispace_Stm_CM4_Smoke.elf
$tapInterface?="tap0"

mach create $name
machine LoadPlatformDescription @/Users/giuliomastromartino/Documents/Polispace/DEV/MICRO_ROS_ETH-main/Test_Board_Sensore/simulation/platform/nucleo_h755zi_q.repl

logLevel 1

showAnalyzer sysbus.usart3

emulation CreateSwitch "switch"
emulation CreateTap $tapInterface "tap"
connector Connect host.tap switch
connector Connect ethernet switch

sysbus LoadELF $bin
sysbus AddWatchpointHook 0x40004828 1 Write "self.InfoLog('UART3:' + chr(value & 0xFF))"
sysbus AddWatchpointHook 0x40004828 4 Write "self.InfoLog('UART3:' + chr(value & 0xFF))"

start
