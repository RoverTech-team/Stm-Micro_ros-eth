// Minimal dual-core STM32H755ZI-Q board model for CM7-first Renode bring-up.
// This keeps the peripheral set intentionally small and focused on the dual-core
// smoke firmware: shared flash/RAM, RCC/SYSCFG/HSEM, GPIO, UART console, LEDs,
// user button, and Ethernet MAC/PHY wiring.

cm7: CPU.CortexM @ sysbus
    cpuType: "cortex-m7"
    cpuId: 0
    numberOfMPURegions: 16
    nvic: nvic_cm7

cm4: CPU.CortexM @ sysbus
    cpuType: "cortex-m4"
    cpuId: 1
    numberOfMPURegions: 16
    nvic: nvic_cm4
    init:
        IsHalted: true

nvic_cm7: IRQControllers.NVIC @ sysbus new Bus.BusPointRegistration {
        address: 0xE000E000;
        cpu: cm7
    }
    systickFrequency: 96_000_000
    priorityMask: 0xF0
    -> cm7@0

nvic_cm4: IRQControllers.NVIC @ sysbus new Bus.BusPointRegistration {
        address: 0xE000E000;
        cpu: cm4
    }
    systickFrequency: 96_000_000
    priorityMask: 0xF0
    -> cm4@0

exti_cm7: IRQControllers.STM32H7_EXTI @ sysbus new Bus.BusPointRegistration {
        address: 0x58000000;
        cpu: cm7
    }
    [0-4] -> nvic_cm7@[6-10]
    [5-9] -> nvicInput23_cm7@[0-4]
    [10-15] -> nvicInput40_cm7@[0-5]
    [16-19] -> nvic_cm7@[1, 41, 2, 3]
    [20, 21] -> nvicInput137_cm7@[0-1]
    [22-24] -> nvic_cm7@[31, 33, 72]
    [26-29] -> nvic_cm7@[37-39, 71]
    [30-33] -> nvic_cm7@[52, 53, 82, 83]
    [34-35] -> nvicInput142_cm7@[0-1]
    [36-40] -> nvic_cm7@[35, 36, 51, 84, 85]
    41 -> nvicInput86_cm7@0
    [42-44] -> nvic_cm7@[119, 76, 100]
    [47, 48, 50, 52, 53] -> nvic_cm7@[93, 138-141]
    54 -> nvic_cm7@115
    [55-60] -> nvicInput149_cm7@[0-5]
    [61-64] -> nvic_cm7@[5, 95, 96, 142]
    65 -> nvicInput86_cm7@1
    [66-73] -> nvic_cm7@[129-136]
    [74-76] -> nvic_cm7@[128, 127, 146]
    [85, 86] -> nvic_cm7@[94, 61]

nvicInput23_cm7: Miscellaneous.CombinedInput @ none
    numberOfInputs: 5
    -> nvic_cm7@23

nvicInput40_cm7: Miscellaneous.CombinedInput @ none
    numberOfInputs: 6
    -> nvic_cm7@40

nvicInput86_cm7: Miscellaneous.CombinedInput @ none
    numberOfInputs: 2
    -> nvic_cm7@86

nvicInput137_cm7: Miscellaneous.CombinedInput @ none
    numberOfInputs: 2
    -> nvic_cm7@137

nvicInput142_cm7: Miscellaneous.CombinedInput @ none
    numberOfInputs: 2
    -> nvic_cm7@142

nvicInput149_cm7: Miscellaneous.CombinedInput @ none
    numberOfInputs: 6
    -> nvic_cm7@149

flashBank1: Memory.MappedMemory @ sysbus 0x08000000
    size: 0x100000

flashBank2: Memory.MappedMemory @ sysbus 0x08100000
    size: 0x100000

flashController: MTD.STM32H7_FlashController @ sysbus 0x52002000
    flash1: flashBank1
    flash2: flashBank2

itcm_cm7: Memory.MappedMemory @ sysbus new Bus.BusPointRegistration {
        address: 0x00000000;
        cpu: cm7
    }
    size: 0x10000

dtcm_cm7: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x20000

system_flash_ro: Memory.MappedMemory @ sysbus 0x1FF00000
    size: 0x20000
    init:
        WriteWord 0x1E880 0x800

// The CM4 firmware is linked against the 0x10000000 alias into the D2 SRAM.
sram_cm4: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x48000

axiSram: Memory.MappedMemory @ sysbus 0x24000000
    size: 0x80000

sram1: Memory.MappedMemory @ sysbus 0x30000000
    size: 0x20000

sram2: Memory.MappedMemory @ sysbus 0x30020000
    size: 0x20000

sram3: Memory.MappedMemory @ sysbus 0x30040000
    size: 0x8000

sram4: Memory.MappedMemory @ sysbus 0x38000000
    size: 0x10000

backupSram: Memory.MappedMemory @ sysbus 0x38800000
    size: 0x1000

syscfg: Miscellaneous.STM32_SYSCFG @ sysbus 0x58000400
    [0-15] -> exti_cm7@[0-15]

gpioPortA: GPIOPort.STM32_GPIOPort @ sysbus <0x58020000, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#0@[0-15]

gpioPortB: GPIOPort.STM32_GPIOPort @ sysbus <0x58020400, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#1@[0-15]

gpioPortC: GPIOPort.STM32_GPIOPort @ sysbus <0x58020800, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#2@[0-15]

gpioPortD: GPIOPort.STM32_GPIOPort @ sysbus <0x58020C00, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#3@[0-15]

gpioPortE: GPIOPort.STM32_GPIOPort @ sysbus <0x58021000, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#4@[0-15]

gpioPortF: GPIOPort.STM32_GPIOPort @ sysbus <0x58021400, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#5@[0-15]

gpioPortG: GPIOPort.STM32_GPIOPort @ sysbus <0x58021800, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#6@[0-15]

gpioPortH: GPIOPort.STM32_GPIOPort @ sysbus <0x58021C00, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#7@[0-15]

gpioPortI: GPIOPort.STM32_GPIOPort @ sysbus <0x58022000, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#8@[0-15]

gpioPortJ: GPIOPort.STM32_GPIOPort @ sysbus <0x58022400, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#9@[0-15]

gpioPortK: GPIOPort.STM32_GPIOPort @ sysbus <0x58022800, +0x400>
    numberOfAFs: 16
    [0-15] -> syscfg#10@[0-15]

usart2: UART.STM32F7_USART @ sysbus 0x40004400
    frequency: 125000000
    IRQ -> exti_cm7@27

usart3: UART.STM32F7_USART @ sysbus 0x40004800
    frequency: 125000000
    IRQ -> exti_cm7@28

timer2: Timers.STM32_Timer @ sysbus 0x40000000
    initialLimit: 0xffffffff
    frequency: 250000000
    -> nvic_cm7@28

timer1: Timers.STM32_Timer @ sysbus 0x40010000
    initialLimit: 0xffff
    frequency: 250000000
    -> nvic_cm7@25

rcc: Miscellaneous.STM32H7_RCC @ sysbus 0x58024400

crc: CRC.STM32_CRC @ sysbus 0x58024C00
    series: STM32Series.F0
    configurablePoly: true

hsem: Miscellaneous.STM32H7_HardwareSemaphore @ sysbus 0x58026400

ethernet: Network.SynopsysDWCEthernetQualityOfService @ {
    sysbus 0x40028000;
    sysbus new Bus.BusMultiRegistration { address: 0x40028C00; size: 0x200; region: "mtl" };
    sysbus new Bus.BusMultiRegistration { address: 0x40029000; size: 0x200; region: "dma" }
    }
    systemClockFrequency: 50000000
    dmaBusWidth: BusWidth.Bits32
    -> nvic_cm7@61

phy: Network.EthernetPhysicalLayer @ ethernet 0
    BasicControl: 0x3100
    BasicStatus: 0x782D
    Id1: 0x0007
    Id2: 0xC130
    AutoNegotiationAdvertisement: 0x01E1
    AutoNegotiationLinkPartnerBasePageAbility: 0x0001
    AutoNegotiationExpansion: 0x0064
    AutoNegotiationNextPageTransmit: 0x2001

GreenLED: Miscellaneous.LED @ gpioPortB 0

YellowLED: Miscellaneous.LED @ gpioPortE 1

RedLED: Miscellaneous.LED @ gpioPortB 14

UserButton1: Miscellaneous.Button @ gpioPortC 13
    -> gpioPortC@13

gpioPortB:
    0 -> GreenLED@0
    14 -> RedLED@0

gpioPortE:
    1 -> YellowLED@0

sysbus:
    init:
        Tag <0x58024418, 0x5802441B> "RCC_CR" 0x00000001
        Tag <0x5802441C, 0x5802441F> "RCC_HSICFGR" 0x00000000
        Tag <0x58024420, 0x58024423> "RCC_CRRCR" 0x00000000
        Tag <0x58024430, 0x58024433> "RCC_CFGR" 0x00000000
        Tag <0x580244D8, 0x580244DB> "RCC_AHB4ENR" 0x000001FF
        Tag <0x580244E8, 0x580244EB> "RCC_D2CCIP2R" 0x00000000
        Tag <0x580244F0, 0x580244F3> "RCC_D3CCIPR" 0x00000000
        Tag <0x580244F4, 0x580244F7> "RCC_CSR" 0x00000002
        Tag <0x5C001000, 0x5C0013FF> "DBGMCU_D3"
        Tag <0x58027000, 0x580273FF> "RAMECC3"
        Tag <0x58025800, 0x58025BFF> "DMAMUX2"
        Tag <0x58024800, 0x58024BFF> "PWR"
        Tag <0x58024804, 0x58024807> "PWR_CSR1_ACTVOSRDY" 0x2000
        Tag <0x5802480C, 0x5802480F> "PWR_CR3"
        Tag <0x58024818, 0x58024818> "D3CR" 0x2000
        Tag <0x58000404, 0x58000407> "SYSCFG_PMCR" 0x00000000
        Tag <0x58005400, 0x580057FF> "SAI4"
        Tag <0x58003C00, 0x58003FFF> "VREF"
        Tag <0x58003800, 0x58003BFF> "COMP1_-_COMP2"
        Tag <0x58001400, 0x580017FF> "SPI6"
        Tag <0x5800042C, 0x5800042F> "SYSCFG_UR1_BOOT_BITS" 0x00030000
        Tag <0x580000E8, 0x580000EB> "EXTI_CPUIMR3" 0x00000000
        Tag <0x52009000, 0x520093FF> "RAMECC1"
        Tag <0x52008000, 0x52008FFF> "Delay_Block_SDMMC1"
        Tag <0x52006000, 0x52006FFF> "Delay_Block_QUADSPI"
        Tag <0x52004000, 0x52004FFF> "FMC_control_registers"
        Tag <0x52003000, 0x52003FFF> "JPEG"
        Tag <0x52000000, 0x52000FFF> "MDMA"
        Tag <0x51000000, 0x510FFFFF> "GPV_matrix_(AXIM)"
        Tag <0x50003000, 0x50003FFF> "WWDG1"
        Tag <0x48023000, 0x480233FF> "RAMECC2"
        Tag <0x48022800, 0x48022BFF> "Delay_Block_SDMMC2"
        Tag <0x48022400, 0x480227FF> "SDMMC2"
        Tag <0x48021400, 0x480217FF> "HASH"
        Tag <0x48020000, 0x480203FF> "DCMI"
        Tag <0x40080000, 0x400BFFFF> "USB2_OTG_FS"
        Tag <0x40040000, 0x4007FFFF> "USB1_OTG_HS"
        Tag <0x40017400, 0x400177FF> "HRTIM"
        Tag <0x40017000, 0x400173FF> "DFSDM1"
        Tag <0x40016000, 0x400163FF> "SAI3"
        Tag <0x40015C00, 0x40015FFF> "SAI2"
        Tag <0x40015800, 0x40015BFF> "SAI1"
        Tag <0x40015000, 0x400153FF> "SPI5"
        Tag <0x40013000, 0x400133FF> "SPI1_/_I2S1"
        Tag <0x4000A800, 0x4000ABFF> "CAN_CCU"
        Tag <0x40009400, 0x400097FF> "MDIOS"
        Tag <0x40009000, 0x400093FF> "OPAMP"
        Tag <0x40008800, 0x40008BFF> "SWPMI"
        Tag <0x40008400, 0x400087FF> "CRS"
        Tag <0x40007400, 0x400077FF> "DAC1"
        Tag <0x40006C00, 0x40006FFF> "HDMI-CEC"
        Tag <0x40004000, 0x400043FF> "SPDIFRX1"
        Tag <0x40003C00, 0x40003FFF> "SPI3_/_I2S3"
        Tag <0x40003800, 0x40003BFF> "SPI2_/_I2S2"
