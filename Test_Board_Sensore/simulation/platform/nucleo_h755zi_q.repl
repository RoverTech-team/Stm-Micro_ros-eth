using "/Users/giuliomastromartino/Documents/Polispace/DEV/MICRO_ROS_ETH-main/Renode.app/Contents/MacOS/platforms/cpus/stm32h743.repl"

// Reuse the STM32H7 single-core model and pin the CPU to Cortex-M4 for
// CM4-first firmware bring-up on the H755 board.
cpu:
    cpuType: "cortex-m4"

// The CM4 core on STM32H755 accesses D2 SRAM through the 0x10000000 alias.
sram_cm4: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x48000

GreenLED: Miscellaneous.LED @ gpioPortB 0

YellowLED: Miscellaneous.LED @ gpioPortE 1

RedLED: Miscellaneous.LED @ gpioPortB 14

UserButton1: Miscellaneous.Button @ gpioPortC 13
    -> gpioPortC@13

gpioPortB:
    0 -> GreenLED@0
    14 -> RedLED@0

gpioPortE:
    1 -> YellowLED@0

// Ethernet MAC is inherited from the STM32H7 CPU model. Add the Nucleo PHY so
// future Ethernet firmware can negotiate link against a realistic default peer.
phy: Network.EthernetPhysicalLayer @ ethernet 0
    BasicControl: 0x3100
    BasicStatus: 0x782D
    Id1: 0x0007
    Id2: 0xC130
    AutoNegotiationAdvertisement: 0x01E1
    AutoNegotiationLinkPartnerBasePageAbility: 0x0001
    AutoNegotiationExpansion: 0x0064
    AutoNegotiationNextPageTransmit: 0x2001

sysbus:
    init:
        // STM32H7 CM4 startup polls these power-control status bits before
        // entering SystemInit and the HAL clock tree setup.
        Tag <0x58024800, 0x58024803> "PWR_CR1_DBP_SET" 0x100
        Tag <0x58024804, 0x58024807> "PWR_CSR1_ACTVOSRDY" 0x2000
        Tag <0x58024808, 0x5802480B> "PWR_CR2_BREN_SET" 0x1
        Tag <0x58024818, 0x5802481B> "PWR_D3CR_VOSRDY" 0x2000
