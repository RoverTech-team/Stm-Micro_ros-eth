FROM ros:humble-ros-base-jammy

ENV DEBIAN_FRONTEND=noninteractive
ENV ROS_DISTRO=humble

RUN apt-get update && apt-get install -y \
    python3-pip \
    python3-venv \
    curl \
    iproute2 \
    iputils-ping \
    net-tools \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --no-cache-dir \
    pytest>=7.0.0 \
    pytest-timeout>=2.0.0 \
    pytest-json-report>=1.5.0 \
    requests>=2.28.0 \
    docker>=6.0.0 \
    websocket-client>=1.0.0

WORKDIR /app/tests

COPY conftest.py ./
COPY mock_stm32_client.py ./
COPY test_dashboard_api.py ./
COPY test_e2e_pipeline.py ./
COPY test_xrcedds_transport.py ./
COPY __init__.py ./

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

RUN mkdir -p /app/test_results /app/reports

RUN echo '#!/bin/bash\n\
set -e\n\
source /opt/ros/humble/setup.bash\n\
exec pytest -v --tb=short --timeout=60 -m e2e --json-report --json-report-file=/app/test_results/report.json /app/tests/ "$@"\n\
' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]

CMD []
