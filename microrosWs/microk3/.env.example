# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=127.0.0.1
FLASK_PORT=5050

# Security (REQUIRED - Generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-generate-a-real-one

# Authentication (Change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Data Storage
DATA_FILE=data/system_data.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ROS / Renode bridge
ROS_DOMAIN_ID=0
RENODE_NODE_ID=755
RENODE_NODE_NAME=renode-stm32h755
RENODE_HEARTBEAT_TOPIC=heartbeat
RENODE_HEARTBEAT_TIMEOUT_SEC=5.0
