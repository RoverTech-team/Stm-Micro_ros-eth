FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV ARM_GNU_TOOLCHAIN_VERSION=14.2.rel1
ENV ARM_GNU_TOOLCHAIN_ARCHIVE=arm-gnu-toolchain-14.2.rel1-aarch64-arm-none-eabi.tar.xz
ENV ARM_GNU_TOOLCHAIN_URL=https://developer.arm.com/-/media/Files/downloads/gnu/14.2.rel1/binrel/arm-gnu-toolchain-14.2.rel1-aarch64-arm-none-eabi.tar.xz
ENV ARM_GNU_TOOLCHAIN_DIR=/opt/arm-gnu-toolchain-14.2.rel1-aarch64-arm-none-eabi

RUN rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/* \
    && apt-get update -o Acquire::AllowInsecureRepositories=true -o Acquire::AllowDowngradeToInsecureRepositories=true \
    && apt-get install -y --allow-unauthenticated --no-install-recommends \
    ca-certificates \
    make \
    tar \
    wget \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

RUN wget -qO "/tmp/${ARM_GNU_TOOLCHAIN_ARCHIVE}" "${ARM_GNU_TOOLCHAIN_URL}" \
    && tar xf "/tmp/${ARM_GNU_TOOLCHAIN_ARCHIVE}" -C /opt \
    && rm -f "/tmp/${ARM_GNU_TOOLCHAIN_ARCHIVE}"

ENV PATH="${ARM_GNU_TOOLCHAIN_DIR}/bin:${PATH}"

WORKDIR /workspace

ENTRYPOINT ["/bin/bash", "-lc"]
