/*
 * STM32H755 Platform Description for Renode Simulation
 * Simplified single-core Cortex-M7 configuration
 */

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m7"
    numberOfMPURegions: 16
    nvic: nvic

nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    systickFrequency: 480_000_000
    priorityMask: 0xF0
    -> cpu@0

flash: Memory.MappedMemory @ sysbus 0x08000000
    size: 0x200000

dtcm: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x20000

sram: Memory.MappedMemory @ sysbus 0x24000000
    size: 0x80000

sram_d2: Memory.MappedMemory @ sysbus 0x30000000
    size: 0x48000
