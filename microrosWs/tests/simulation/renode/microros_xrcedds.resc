/*
 * micro-ROS XRCE-DDS Simulation Script for STM32H755
 * 
 * This script sets up the Renode simulation environment for testing
 * micro-ROS applications with XRCE-DDS UDP transport.
 * 
 * Configuration:
 * - STM32H755 CM7 core at 480MHz
 * - Ethernet connected to host network via external bridge
 * - micro-ROS agent at 172.17.0.1:8888 (Docker host) or localhost:8888
 * - UART debug output on USART3
 */

using sysbus
using "stm32h755_networked.repl"

// ========================================
// Simulation Configuration
// ========================================

logLevel 3
simulation speed 1.0

// ========================================
// Paths
// ========================================

$FIRMWARE_PATH = @../../../Micro_ros_eth/microroseth/Makefile/CM7/build/MicroRosEth_CM7.elf
$UART_LOG = @../results/xrcedds_uart.log
$PCAP_FILE = @../results/xrcedds_capture.pcap

// ========================================
// Network Configuration
// ========================================

// Device network configuration (must match firmware settings)
$DEVICE_IP = "192.168.1.100"
$DEVICE_NETMASK = "255.255.255.0"
$DEVICE_GATEWAY = "192.168.1.1"
$DEVICE_MAC = "00:02:F7:11:22:33"

// micro-ROS Agent configuration
// Use 172.17.0.1 for Docker host gateway, or 127.0.0.1 for localhost
$AGENT_IP = "172.17.0.1"
$AGENT_PORT = 8888

// ========================================
// UART Setup for Debug Output
// ========================================

showAnalyzer usart3
logUart usart3 $UART_LOG

// Create UART analyzer for micro-ROS output
uart3Analyzer:
    Setup 115200

// ========================================
// Ethernet Network Setup
// ========================================

networkSetup:
    // Enable Ethernet MAC
    ethernet Reset
    
    // Configure PHY link status
    phy SetLinkStatus true
    
    // Create external network connection
    // This allows Renode to communicate with host/Docker
    // Port forwarding: Renode -> Host:8888 -> micro-ROS Agent
    
    echo "Network configuration:"
    echo "  Device IP: $DEVICE_IP"
    echo "  Agent IP: $AGENT_IP"
    echo "  Agent Port: $AGENT_PORT"

// ========================================
// External Network Bridge Setup
// ========================================

// Configure the external control server for host network access
// This enables UDP communication with micro-ROS agent
externalNetwork:
    // Create UDP tunnel to micro-ROS agent
    // The bridge forwards XRCE-DDS packets between firmware and agent
    
    // For communication with Docker host (172.17.0.1) or localhost
    // Port 8888 is the default XRCE-DDS agent port
    connector Start 9999

// ========================================
// Python Network Bridge
// ========================================

// Load Python extension for XRCE-DDS packet handling
emulation LoadPythonExtension "network_bridge.py"

// Create network bridge instance
$bridge = NetworkBridge.Create "xrcedds_bridge"

// Configure bridge to forward packets
$bridge.SetAgentAddress $AGENT_IP $AGENT_PORT
$bridge.SetDeviceAddress $DEVICE_IP 8888
$bridge.EnableLogging true

// ========================================
// Firmware Loading
// ========================================

loadFirmware:
    sysbus LoadELF $FIRMWARE_PATH
    echo "Firmware loaded: $FIRMWARE_PATH"

// ========================================
// Packet Capture (Optional)
// ========================================

startCapture:
    $bridge.StartCapture $PCAP_FILE
    echo "Packet capture started: $PCAP_FILE"

stopCapture:
    $bridge.StopCapture
    echo "Packet capture stopped"

// ========================================
// Simulation Control
// ========================================

runSimulation:
    // Reset all peripherals
    sysbus ResetAll
    
    // Start CPU
    cpu Start
    
    echo "================================"
    echo "STM32H755 XRCE-DDS Simulation"
    echo "================================"
    echo "micro-ROS Agent: $AGENT_IP:$AGENT_PORT"
    echo "Device IP: $DEVICE_IP"
    echo "UART Debug: USART3 @ 115200 baud"
    echo "================================"

// ========================================
// Monitoring and Debugging
// ========================================

// Monitor UART output for XRCE-DDS messages
monitorUart:
    // Wait for specific patterns
    // Patterns are checked in Robot Framework tests

// Show network statistics
showStats:
    $stats = $bridge.GetStatistics
    echo "Network Statistics:"
    echo "  TX Packets: $stats.tx_packets"
    echo "  RX Packets: $stats.rx_packets"
    echo "  TX Bytes: $stats.tx_bytes"
    echo "  RX Bytes: $stats.rx_bytes"
    echo "  XRCE Messages: $stats.xrcedds_messages"

// Show XRCE-DDS session info
showSessions:
    $sessions = $bridge.GetXRCESessions
    echo "XRCE-DDS Sessions:"
    echo $sessions

// ========================================
// Error Injection for Testing
// ========================================

// Inject CRC error on next received packet
injectCrcError:
    $bridge.InjectCrcError
    echo "CRC error injection enabled"

// Inject frame error
injectFrameError:
    $bridge.InjectFrameError
    echo "Frame error injection enabled"

// Simulate network disconnect
disconnectNetwork:
    $bridge.Disconnect
    phy SetLinkStatus false
    echo "Network disconnected"

// Reconnect network
reconnectNetwork:
    $bridge.Connect
    phy SetLinkStatus true
    echo "Network reconnected"

// ========================================
// Initialization Sequence
// ========================================

// Execute setup
networkSetup
externalNetwork

echo "micro-ROS XRCE-DDS simulation ready"
echo "Type 'runSimulation' to start firmware execution"
echo "Type 'showStats' to view network statistics"
