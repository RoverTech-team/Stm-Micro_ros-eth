/*
 * micro-ROS TAP Simulation Script for STM32H755ZIT6
 *
 * This script configures Renode simulation with TAP networking
 * for direct communication between the simulated STM32 and a
 * micro-ROS agent running on the host.
 *
 * Network Configuration:
 *   STM32 IP:      192.168.0.3 (configured in firmware)
 *   Gateway (TAP): 192.168.0.1
 *   Agent IP:      192.168.0.8:8888
 *
 * Prerequisites:
 *   1. Run: sudo ./scripts/setup_tap.sh
 *   2. Start micro-ROS agent: micro-ros-agent udp4 --port 8888 -v6
 *   3. Run this script in Renode
 */

// ========================================
// Create Machine and Load Platform
// ========================================

mach create

machine LoadPlatformDescription @stm32h755_tap.repl

// ========================================
// Create TAP Network Infrastructure
// ========================================

// Create virtual switch for connecting multiple network endpoints
emulation CreateSwitch "eth_switch"

// Create TAP connector to host network
// This bridges the simulated Ethernet with the host's TAP interface
emulation CreateTap "tap0" "tap"

// Connect TAP to switch (host side)
connector Connect host.tap "eth_switch"

// Connect Ethernet MAC to switch (simulation side)
connector Connect sysbus.ethernet "eth_switch"

// ========================================
// Start TAP Interface
// ========================================

host.tap Start

// ========================================
// Load Firmware
// ========================================

// Load the CM7 firmware
// The firmware has hardcoded network configuration:
//   IP: 192.168.0.3
//   Gateway: 192.168.0.1
//   Agent IP: 192.168.0.8:8888

sysbus LoadELF @../../../Micro_ros_eth/microroseth/Makefile/CM7/build/MicroRosEth_CM7.elf

// ========================================
// Simulation Configuration
// ========================================

simulation speed 1.0

logLevel 3

// ========================================
// UART Configuration for Debug
// ========================================

showAnalyzer usart1

// ========================================
// Network Configuration Info
// ========================================

echo "=========================================="
echo "micro-ROS TAP Simulation"
echo "=========================================="
echo "Network Configuration:"
echo "  STM32 IP:   192.168.0.3"
echo "  Gateway:    192.168.0.1"
echo "  Agent IP:   192.168.0.8:8888"
echo "=========================================="
echo ""
echo "Ensure TAP interface is configured:"
echo "  sudo ./scripts/setup_tap.sh"
echo ""
echo "Start micro-ROS agent before running:"
echo "  micro-ros-agent udp4 --port 8888 -v6"
echo "=========================================="

// ========================================
// Start Simulation
// ========================================

start

echo "Simulation started - waiting for firmware boot..."
echo "Watch for XRCE-DDS communication with agent"

// ========================================
// Run for 60 seconds
// ========================================

sleep 60

echo "Simulation completed after 60 seconds"

quit
